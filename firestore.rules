rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function currentUserPath() {
      return /databases/$(database)/documents/Users/$(request.auth.uid);
    }

    function currentRole() {
      return signedIn() && exists(currentUserPath())
        ? get(currentUserPath()).data.role
        : null;
    }

    function currentRoleLower() {
      let role = currentRole();
      return role is string ? role.lower() : '';
    }

    function isDriver() {
      return currentRoleLower() == 'driver';
    }

    function isStore() {
      return currentRoleLower() == 'store';
    }

    function isCustomer() {
      return currentRoleLower() == 'customer';
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isValidRole(role) {
      return role in ['Customer', 'Store', 'Driver', 'customer', 'store', 'driver'];
    }

    function hasCoreFields(data, uid) {
      return data.user_id == uid
        && data.user_name is string
        && data.user_name.size() >= 3
        && data.email is string
        && data.role is string
        && isValidRole(data.role);
    }

    function hasValidRoleInfo(data) {
      return (
        data.role == 'Driver'
          ? data.driver_info is map && !('store_info' in data)
          : data.role == 'Store'
            ? hasValidStoreInfo(data.store_info) && !('driver_info' in data)
            : !('driver_info' in data) && !('store_info' in data)
      );
    }

    function hasValidStoreInfo(storeInfo) {
      return storeInfo is list
        && storeInfo.size() > 0
        && storeInfo[0] is map
        && storeInfo[0].is_open is bool
        && storeInfo[0].rating is number;
    }

    function canOwnerPatchStoreProfile(uid) {
      return isOwner(uid)
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          'fullName',
          'phone',
          'address',
          'store_name',
          'opening_hours',
          'latitude',
          'longitude',
          'position',
          'store_info',
          'updated_at',
          'updatedAt'
        ])
        && (!('fullName' in request.resource.data) || request.resource.data.fullName is string)
        && (!('phone' in request.resource.data) || request.resource.data.phone is string)
        && (!('address' in request.resource.data) || request.resource.data.address is string)
        && (!('store_name' in request.resource.data) || request.resource.data.store_name is string)
        && (!('opening_hours' in request.resource.data) || request.resource.data.opening_hours is string)
        && (!('latitude' in request.resource.data) || request.resource.data.latitude is number)
        && (!('longitude' in request.resource.data) || request.resource.data.longitude is number)
        && (!('position' in request.resource.data) || request.resource.data.position is string)
        && (!('updated_at' in request.resource.data) || request.resource.data.updated_at is timestamp)
        && (!('updatedAt' in request.resource.data) || request.resource.data.updatedAt is timestamp)
        && (!('store_info' in request.resource.data) || hasValidStoreInfo(request.resource.data.store_info));
    }

    function isStoreUser(uid) {
      return signedIn()
        && request.auth.uid == uid
        && exists(/databases/$(database)/documents/Users/$(uid))
        && get(/databases/$(database)/documents/Users/$(uid)).data.role == 'Store';
    }

    function isValidFoodShape(data, foodId) {
      return data.food_id == foodId
        && data.store_id == request.auth.uid
        && data.name is string
        && data.description is string
        && data.category_id is string
        && data.image is string
        && data.price is number
        && data.is_available is bool
        && data.options is map
        && data.options.size is string
        && data.options.size in ['S', 'M', 'L']
        && data.avg_rating is number
        && data.total_ratings is int;
    }

    match /Users/{uid} {
      // Cho phép đọc thông tin nếu là chủ sở hữu HOẶC là tài khoản Cửa hàng/Tài xế (để khách hàng tìm kiếm)
      allow read, list: if signedIn();
      
      allow create: if isOwner(uid)
        && hasCoreFields(request.resource.data, uid)
        && request.resource.data.created_at is timestamp
        && hasValidRoleInfo(request.resource.data);

      function canAnyonePatchStoreAggregates(targetUid) {
        return signedIn()
          && exists(/databases/$(database)/documents/Users/$(targetUid))
          && (get(/databases/$(database)/documents/Users/$(targetUid)).data.role in ['Store', 'store'])
          && request.resource.data.diff(resource.data).changedKeys().hasOnly([
            'rating',
            'avgRating',
            'avg_rating',
            'totalRatings',
            'total_ratings',
            'updated_at',
            'updatedAt'
          ])
          && (!('rating' in request.resource.data) || request.resource.data.rating is number)
          && (!('avgRating' in request.resource.data) || request.resource.data.avgRating is number)
          && (!('avg_rating' in request.resource.data) || request.resource.data.avg_rating is number)
          && (!('totalRatings' in request.resource.data) || request.resource.data.totalRatings is int)
          && (!('total_ratings' in request.resource.data) || request.resource.data.total_ratings is int)
          && (!('updated_at' in request.resource.data) || request.resource.data.updated_at is timestamp)
          && (!('updatedAt' in request.resource.data) || request.resource.data.updatedAt is timestamp);
      }

      allow update: if (isOwner(uid)
        && (
          (hasCoreFields(request.resource.data, uid)
            && hasValidRoleInfo(request.resource.data))
          || canOwnerPatchStoreProfile(uid)
        ))
        || canAnyonePatchStoreAggregates(uid);

      allow delete: if false;
    }

    // Mirror orders stored under Users/{uid}/Orders/{orderId}
    match /Users/{uid}/Orders/{orderId} {
      allow read, list: if signedIn() && (isOwner(uid) || isStore() || isDriver());

      // Allow creating/updating the customer's own mirror.
      function isCustomerMirrorWrite() {
        return signedIn()
          && isOwner(uid)
          && (
            (('customerId' in request.resource.data) && request.resource.data.customerId == request.auth.uid)
            || (('customer_id' in request.resource.data) && request.resource.data.customer_id == request.auth.uid)
            || (('user_id' in request.resource.data) && request.resource.data.user_id == request.auth.uid)
          );
      }

      // Allow creating/updating the store's mirror when the document is for that store.
      function isStoreMirrorWrite() {
        return signedIn()
          && (('storeId' in request.resource.data && request.resource.data.storeId == uid)
            || ('store_id' in request.resource.data && request.resource.data.store_id == uid));
      }

      allow create: if signedIn() && (isCustomerMirrorWrite() || isStoreMirrorWrite());
      allow update: if signedIn() && (isCustomerMirrorWrite() || isStoreMirrorWrite());
      allow delete: if false;
    }

    match /Usernames/{userNameNorm} {
      allow read: if true;

      allow create: if signedIn()
        && !exists(/databases/$(database)/documents/Usernames/$(userNameNorm))
        && request.resource.data.user_id == request.auth.uid
        && request.resource.data.user_name_norm == userNameNorm
        && request.resource.data.user_name is string
        && request.resource.data.user_name.size() >= 3
        && request.resource.data.email is string;

      allow update: if signedIn()
        && resource.data.user_id == request.auth.uid
        && request.resource.data.user_id == request.auth.uid
        && request.resource.data.user_name_norm == userNameNorm
        && request.resource.data.user_name is string
        && request.resource.data.user_name.size() >= 3
        && request.resource.data.email is string;

      allow delete: if false;
    }

    match /Foods/{foodId} {
      allow read: if true;

      allow create: if signedIn()
        && isStoreUser(request.auth.uid)
        && isValidFoodShape(request.resource.data, foodId);

      function canPatchFoodAggregates() {
        return signedIn()
          && request.resource.data.diff(resource.data).changedKeys().hasOnly([
            'avgRating',
            'avg_rating',
            'rating',
            'totalRatings',
            'total_ratings',
            'updated_at',
            'updatedAt'
          ])
          && (!('avgRating' in request.resource.data) || request.resource.data.avgRating is number)
          && (!('avg_rating' in request.resource.data) || request.resource.data.avg_rating is number)
          && (!('rating' in request.resource.data) || request.resource.data.rating is number)
          && (!('totalRatings' in request.resource.data) || request.resource.data.totalRatings is int)
          && (!('total_ratings' in request.resource.data) || request.resource.data.total_ratings is int)
          && (!('updated_at' in request.resource.data) || request.resource.data.updated_at is timestamp)
          && (!('updatedAt' in request.resource.data) || request.resource.data.updatedAt is timestamp);
      }

      allow update: if (signedIn()
        && isStoreUser(request.auth.uid)
        && resource.data.store_id == request.auth.uid
        && isValidFoodShape(request.resource.data, foodId))
        || canPatchFoodAggregates();

      allow delete: if signedIn()
        && isStoreUser(request.auth.uid)
        && resource.data.store_id == request.auth.uid;
    }

    match /Categories/{categoryId} {
      allow read: if true;
      allow write: if false;
    }

    // Orders: minimal rules to support driver flow (view finding orders + accept).
    // NOTE: This rule intentionally avoids enforcing a full order schema because
    // the app code may evolve. It focuses on protecting ownership and preventing
    // drivers from mutating arbitrary fields.
    match /Orders/{orderId} {
            function canCustomerSubmitReview() {
              return signedIn()
                && canCustomerSee(resource.data)
                && request.resource.data.diff(resource.data).changedKeys().hasOnly([
                  'rating',
                  'review',
                  'updated_at',
                  'updatedAt'
                ])
                && (!('rating' in resource.data) || resource.data.rating == null || resource.data.rating == 0)
                && (!('review' in resource.data) || resource.data.review == null || resource.data.review == '')
                && ('rating' in request.resource.data)
                && request.resource.data.rating is number
                && request.resource.data.rating >= 1
                && request.resource.data.rating <= 5
                && ('review' in request.resource.data)
                && request.resource.data.review is string
                && (!('updated_at' in request.resource.data) || request.resource.data.updated_at is timestamp)
                && (!('updatedAt' in request.resource.data) || request.resource.data.updatedAt is timestamp);
            }
      function isFindingStatus(status) {
        return status in ['dang_tim_xe', 'finding_driver', 'Searching', 'searching'];
      }

      function effectiveStatus(order) {
        return ('order_status' in order) ? order.order_status : order.status;
      }

      function requestedStatus(order) {
        return ('order_status' in order) ? order.order_status : order.status;
      }

      function hasNoDriverAssigned(data) {
        return !('driver_id' in data) || data.driver_id == '' || data.driver_id == null;
      }

      function canDriverSee(order) {
        return isDriver() && (
          // See open orders while finding drivers.
          (isFindingStatus(effectiveStatus(order)) && hasNoDriverAssigned(order))
          // Or see orders already assigned to this driver.
          || ('driver_id' in order && order.driver_id == request.auth.uid)
        );
      }

      function canStoreSee(order) {
        return isStore() && ('store_id' in order) && order.store_id == request.auth.uid;
      }

      function canCustomerSee(order) {
        return isCustomer() && (
          (('customer_id' in order) && order.customer_id == request.auth.uid)
          || (('user_id' in order) && order.user_id == request.auth.uid)
        );
      }

      function canDriverAcceptOrder() {
        let current = effectiveStatus(resource.data);
        let next = requestedStatus(request.resource.data);
        return isDriver()
          && isFindingStatus(current)
          && hasNoDriverAssigned(resource.data)
          && request.resource.data.driver_id == request.auth.uid
          && (next in ['dang_chuan_bi', 'Preparing'])
          && request.resource.data.diff(resource.data).changedKeys().hasOnly([
            'status',
            'order_status',
            'driver_id',
            'driver_name',
            'accepted_at',
            'updated_at'
          ])
          && (!('accepted_at' in request.resource.data) || request.resource.data.accepted_at is timestamp)
          && (!('updated_at' in request.resource.data) || request.resource.data.updated_at is timestamp);
      }

      function canStoreUpdateOrderStatus() {
        let next = requestedStatus(request.resource.data);
        return isStore()
          && ('store_id' in resource.data)
          && resource.data.store_id == request.auth.uid
          && ('store_id' in request.resource.data)
          && request.resource.data.store_id == request.auth.uid
          && (next in ['pending', 'preparing', 'delivering', 'completed', 'cancelled'])
          && request.resource.data.diff(resource.data).changedKeys().hasOnly([
            'status',
            'order_status',
            'updated_at',
            'updatedAt'
          ])
          && (!('updated_at' in request.resource.data) || request.resource.data.updated_at is timestamp)
          && (!('updatedAt' in request.resource.data) || request.resource.data.updatedAt is timestamp);
      }

      allow read: if signedIn() && (canDriverSee(resource.data) || canStoreSee(resource.data) || canCustomerSee(resource.data));

      // Customer/store create/update flows are not implemented in code yet.
      // Keep create denied by default.
      allow create: if false;

      // Allow driver accept flow, store status updates, and customer review submission.
      allow update: if signedIn() && (canDriverAcceptOrder() || canStoreUpdateOrderStatus() || canCustomerSubmitReview());

      allow delete: if false;
    }

    // Lowercase reviews collection used by the app.
    match /reviews/{reviewId} {
      function canReviewerSee(review) {
        return signedIn() && ('user_id' in review) && review.user_id == request.auth.uid;
      }

      function canStoreSeeReview(review) {
        return isStore() && ('store_id' in review) && review.store_id == request.auth.uid;
      }

      function isValidNewReview() {
        return signedIn()
          && request.resource.data.user_id == request.auth.uid
          && request.resource.data.order_id is string
          && request.resource.data.store_id is string
          && request.resource.data.rating is int
          && request.resource.data.rating >= 1
          && request.resource.data.rating <= 5
          && request.resource.data.comment is string
          && request.resource.data.comment.size() > 0;
      }

      allow read: if canStoreSeeReview(resource.data) || canReviewerSee(resource.data);
      allow create: if isValidNewReview();
      allow update: if false;
      allow delete: if false;
    }

    // Legacy/unused (kept for backward compatibility)
    match /Reviews/{reviewId} {
      function canStoreSeeReview(review) {
        return isStore() && ('store_id' in review) && review.store_id == request.auth.uid;
      }

      function canStoreReplyReview() {
        return isStore()
          && ('store_id' in resource.data)
          && resource.data.store_id == request.auth.uid
          && ('store_id' in request.resource.data)
          && request.resource.data.store_id == request.auth.uid
          && request.resource.data.diff(resource.data).changedKeys().hasOnly([
            'owner_reply',
            'ownerReply',
            'store_reply',
            'reply',
            'owner_replied_at',
            'updated_at',
            'updatedAt'
          ])
          && (!('owner_replied_at' in request.resource.data) || request.resource.data.owner_replied_at is timestamp)
          && (!('updated_at' in request.resource.data) || request.resource.data.updated_at is timestamp)
          && (!('updatedAt' in request.resource.data) || request.resource.data.updatedAt is timestamp);
      }

      allow read: if signedIn() && canStoreSeeReview(resource.data);
      allow create: if false;
      allow update: if signedIn() && canStoreReplyReview();
      allow delete: if false;
    }
  }
}
